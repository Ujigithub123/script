-- =============================================

local client = getClient()

-- ============= CONFIG =============
local CONFIG = {
    itemid        = 296,
    hits          = 5,
    direction     = "down",
    hit_delay     = { min = 450, max = 690 },
    place_delay   = { min = 500, max = 900 },
    collect       = true,
    collect_delay = { min = 500, max = 900 },
    log           = true
}
-- ==================================

local function log(msg)
    if CONFIG.log then
        print("[PNB] " .. tostring(msg))
    end
end

local function getTargetTile(pos, direction)
    local x, y = pos.x, pos.y
    if direction == "down"  then return Vector2i.new(x, y + 1) end
    if direction == "up"    then return Vector2i.new(x, y - 1) end
    if direction == "left"  then return Vector2i.new(x - 1, y) end
    if direction == "right" then return Vector2i.new(x + 1, y) end
    return Vector2i.new(x, y + 1)
end

-- Only count blocks, ignore seeds
local function getCount(itemid)
    local inv = client:inventory()
    local total = 0
    for _, item in pairs(inv.items) do
        if item.id == itemid and item.type == InventoryItemType.block then
            total = total + item.amount
        end
    end
    return total
end

-- Check if tile has a foreground block
local function hasBlock(tilePoint)
    local world = client:world()
    local tile = world:tile(tilePoint)
    if tile and tile.foreground and tile.foreground > 0 then
        return true
    end
    return false
end

local function pnb(itemid, hits, direction)
    itemid    = itemid    or CONFIG.itemid
    hits      = hits      or CONFIG.hits
    direction = direction or CONFIG.direction

    sleep(2000)
    local startPos  = client:point()
    local tilePoint = getTargetTile(startPos, direction)
    local totalUsed = 0

    log(string.format("Start PNB | Item: %d | Hits: %d | Direction: %s", itemid, hits, direction))
    log(string.format("Start pos: (%d,%d) | Target tile: (%d,%d)", startPos.x, startPos.y, tilePoint.x, tilePoint.y))
    log(string.format("Blocks in inventory: %d", getCount(itemid)))

    while getCount(itemid) > 0 do

        if hasBlock(tilePoint) then
            -- Tile has a block, hit it
            log("Block detected, hitting...")
            for i = 1, hits do
                client:hit(tilePoint)
                log(string.format("Hit %d/%d tile (%d,%d)", i, hits, tilePoint.x, tilePoint.y))
                sleep(math.random(CONFIG.hit_delay.min, CONFIG.hit_delay.max))
            end

            if CONFIG.collect then
                -- Move to tile to collect drops
                client:setPoint(tilePoint, false)
                sleep(math.random(CONFIG.collect_delay.min, CONFIG.collect_delay.max))

                client:collect(tilePoint.x, tilePoint.y)
                log("Collected drops")
                sleep(math.random(CONFIG.collect_delay.min, CONFIG.collect_delay.max))

                -- Return to start position
                client:setPoint(startPos, false)
                sleep(math.random(CONFIG.collect_delay.min, CONFIG.collect_delay.max))
            end
        else
            -- Tile is empty, skip hitting
            log("Tile empty, skipping hit...")
        end

        -- Place block
        client:place(tilePoint, itemid, InventoryItemType.block)
        totalUsed = totalUsed + 1
        log(string.format("Placed #%d | Remaining: %d", totalUsed, getCount(itemid)))

        sleep(math.random(CONFIG.place_delay.min, CONFIG.place_delay.max))
    end

    log(string.format("PNB done! Total placed: %d", totalUsed))
end

pnb(CONFIG.itemid, CONFIG.hits, CONFIG.direction)
